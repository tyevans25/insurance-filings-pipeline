# =============================================================================
# LLM Configuration
# =============================================================================

# LLM Provider: 'claude' or 'ollama'
# - Use 'claude' for development and demo (default)
# - Use 'ollama' for GSU deployment
LLM_PROVIDER=claude

# -----------------------------------------------------------------------------
# Claude (Anthropic) Configuration
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your_claude_api_key_here

# -----------------------------------------------------------------------------
# Ollama (GSU Server) Configuration
# -----------------------------------------------------------------------------
# Only needed when LLM_PROVIDER=ollama

# GSU Ollama endpoint
OLLAMA_BASE_URL=https://gpu-01.insight.gsu.edu:11443

# Your GSU API key (from https://www.insight.gsu.edu/wiki/doku.php?id=api_key_manager)
OLLAMA_API_KEY=your_gsu_api_key_here

# Model to use with Ollama (llama3, mistral, etc.)
OLLAMA_MODEL=llama3

# =============================================================================
# Application Configuration
# =============================================================================

# Environment mode (development or production)
NODE_ENV=development

# Database Configuration (existing)
# ... your existing database env vars ...